{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=enkl;Username=enkl;Password=enkl_dev_password"
  },
  "Jwt": {
    "SigningKey": "dev-only-signing-key-change-me-please-32chars-min",
    "Issuer": "Enkl.Api",
    "Audience": "Enkl.App",
    "ExpiryHours": 8
  },
  "App": {
    // The browser-facing origin (scheme + host, no trailing slash) this API is reached at. SAML
    // needs a fixed, correct SP entity id / ACS URL to register with an IdP — Request.Scheme can't
    // be trusted for that here, since nginx (web/nginx.conf) proxies to this API over plain HTTP
    // internally regardless of what the browser actually used, and there's no
    // X-Forwarded-Proto/UseForwardedHeaders wiring to recover the original scheme.
    "PublicBaseUrl": "http://localhost"
  },
  "RunMigrationsOnStartup": true
}
