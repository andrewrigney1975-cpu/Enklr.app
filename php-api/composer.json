{
    "name": "enkl/php-api",
    "description": "Self-hosted PHP + standalone PostgreSQL API tier for Enkl — a parity port of api/Enkl.Api (the .NET API), runnable in parallel to it. Same HTTP contract, so the existing frontend (src/js/api.js) works unmodified against either backend.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pgsql": "*",
        "firebase/php-jwt": "^7.1",
        "monolog/monolog": "^3.0",
        "onelogin/php-saml": "^4.3",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Enkl\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Enkl\\Api\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
